#!/usr/bin/env python3
"""
nextboot-talos — install Talos Linux on this machine on next boot.

Generated by k3s-to-talos. Do not edit manually.

This script:
  1. Downloads the Talos Linux disk image for the target version
  2. Verifies the SHA256 hash
  3. Detects the boot disk
  4. Writes the image to disk
  5. Places the machine config in the Talos state partition
  6. Reboots the machine

WARNING: This will ERASE all data on the boot disk.
"""

import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.request

# ── Configuration (injected by k3s-to-talos) ─────────────────────────────────
TALOS_VERSION  = "{{ .Version }}"
IMAGE_URL      = "{{ .ImageURL }}"
EXPECTED_HASH  = "{{ .HashValue }}"
CONFIG_CONTENT = """{{ .ConfigContent }}"""
AUTO_REBOOT    = {{ .Reboot }}
# ─────────────────────────────────────────────────────────────────────────────


def log(msg):
    print(f"[nextboot-talos] {msg}", flush=True)


def die(msg):
    print(f"[nextboot-talos] ERROR: {msg}", file=sys.stderr, flush=True)
    sys.exit(1)


def check_root():
    if os.geteuid() != 0:
        die("This script must be run as root.")


def detect_boot_disk():
    """Detect the primary boot disk (the disk containing the root partition)."""
    # Try to find the device holding /
    try:
        out = subprocess.check_output(
            ["findmnt", "-n", "-o", "SOURCE", "/"],
            text=True
        ).strip()
        # Strip partition number: /dev/sda1 → /dev/sda, /dev/nvme0n1p1 → /dev/nvme0n1
        disk = re.sub(r'p?\d+$', '', out)
        if os.path.exists(disk):
            log(f"Detected boot disk: {disk}")
            return disk
    except Exception:
        pass

    # Fallback: use lsblk
    try:
        out = subprocess.check_output(
            ["lsblk", "-dno", "NAME,TYPE"],
            text=True
        )
        for line in out.splitlines():
            parts = line.split()
            if len(parts) == 2 and parts[1] == "disk":
                disk = f"/dev/{parts[0]}"
                log(f"Using first detected disk: {disk}")
                return disk
    except Exception:
        pass

    die("Could not detect boot disk. Use --disk flag to specify it.")


def download_image(url, dest_path):
    """Download the Talos disk image with progress output."""
    log(f"Downloading Talos {TALOS_VERSION} image...")
    log(f"  URL: {url}")
    log(f"  Destination: {dest_path}")

    def progress(count, block_size, total_size):
        if total_size > 0:
            pct = count * block_size * 100 // total_size
            mb_done = count * block_size // (1024 * 1024)
            mb_total = total_size // (1024 * 1024)
            print(f"\r  {pct}% ({mb_done}/{mb_total} MB)", end="", flush=True)

    urllib.request.urlretrieve(url, dest_path, reporthook=progress)
    print()  # newline after progress
    log("Download complete.")


def verify_hash(path, expected_hash):
    """Verify SHA256 hash of the downloaded file."""
    if not expected_hash:
        log("No hash provided, skipping verification.")
        return

    log("Verifying image integrity...")
    sha256 = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            sha256.update(chunk)

    actual = sha256.hexdigest()
    if actual != expected_hash.lower():
        die(f"Hash mismatch!\n  Expected: {expected_hash}\n  Actual:   {actual}")
    log("Hash verification passed.")


def decompress_if_needed(src_path, tmp_dir):
    """Decompress .zst, .xz, or .gz image if necessary. Returns path to raw image."""
    if src_path.endswith(".zst"):
        log("Decompressing ZST image...")
        raw_path = os.path.join(tmp_dir, "talos.img")
        # Ensure zstd is available
        if shutil.which("zstd") is None:
            log("zstd not found, installing...")
            subprocess.run(["apt-get", "install", "-y", "-q", "zstd"], check=True)
        subprocess.run(["zstd", "-d", src_path, "-o", raw_path, "-f"], check=True)
        return raw_path
    elif src_path.endswith(".xz"):
        log("Decompressing XZ image...")
        raw_path = os.path.join(tmp_dir, "talos.img")
        subprocess.run(["xz", "-d", "-k", "-T0", "-o", raw_path, src_path], check=True)
        return raw_path
    elif src_path.endswith(".gz"):
        log("Decompressing GZ image...")
        raw_path = os.path.join(tmp_dir, "talos.img")
        subprocess.run(["gunzip", "-c", src_path], stdout=open(raw_path, "wb"), check=True)
        return raw_path
    return src_path


def write_image_to_disk(image_path, disk):
    """Write the Talos image to the target disk using dd."""
    log(f"Writing Talos image to {disk}...")
    log("  This will ERASE all data on the disk. Starting in 5 seconds...")
    for i in range(5, 0, -1):
        print(f"  {i}...", flush=True)
        time.sleep(1)

    subprocess.run(
        ["dd", f"if={image_path}", f"of={disk}", "bs=4M", "conv=fsync", "status=progress"],
        check=True
    )
    subprocess.run(["sync"], check=True)
    log(f"Image written to {disk}.")


def write_talos_config(disk, config_content):
    """Write the Talos machine config to the STATE partition."""
    if not config_content.strip():
        log("No machine config provided, skipping config write.")
        return

    # After writing the image, the STATE partition is typically partition 6
    # Talos partition layout: EFI(1), BIOS(2), META(3), STATE(4), EPHEMERAL(5)
    # Try common partition naming schemes
    state_partitions = []
    if "nvme" in disk or "mmcblk" in disk:
        state_partitions = [f"{disk}p4", f"{disk}p6"]
    else:
        state_partitions = [f"{disk}4", f"{disk}6"]

    # Re-read partition table
    subprocess.run(["partprobe", disk], capture_output=True)
    time.sleep(2)

    mounted = False
    with tempfile.TemporaryDirectory() as mount_point:
        for part in state_partitions:
            if not os.path.exists(part):
                continue
            result = subprocess.run(
                ["mount", part, mount_point],
                capture_output=True
            )
            if result.returncode == 0:
                # Write the machine config
                config_path = os.path.join(mount_point, "config.yaml")
                with open(config_path, "w") as f:
                    f.write(config_content)
                subprocess.run(["sync"], check=True)
                subprocess.run(["umount", mount_point], check=True)
                log(f"Machine config written to {part} (STATE partition).")
                mounted = True
                break

    if not mounted:
        log("Warning: Could not mount STATE partition to write config.")
        log("  Talos will boot in maintenance mode. Apply config with:")
        log("  talosctl apply-config --insecure --nodes <ip> --file controlplane.yaml")


def reboot_machine():
    """Reboot the machine into Talos."""
    log("Rebooting machine into Talos Linux...")
    time.sleep(2)
    subprocess.run(["reboot", "-f"])


def main():
    check_root()

    log(f"Starting Talos {TALOS_VERSION} installation")
    log("=" * 60)

    disk = detect_boot_disk()

    with tempfile.TemporaryDirectory() as tmp_dir:
        # Determine filename from URL
        filename = IMAGE_URL.split("/")[-1]
        image_path = os.path.join(tmp_dir, filename)

        download_image(IMAGE_URL, image_path)
        verify_hash(image_path, EXPECTED_HASH)

        raw_path = decompress_if_needed(image_path, tmp_dir)
        write_image_to_disk(raw_path, disk)

    write_talos_config(disk, CONFIG_CONTENT)

    log("=" * 60)
    log("Talos installation complete.")

    if AUTO_REBOOT:
        reboot_machine()
    else:
        log("AUTO_REBOOT is disabled. Reboot manually to boot into Talos:")
        log("  reboot")


if __name__ == "__main__":
    main()
